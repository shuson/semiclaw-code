    "audio-capture-napi": "file:vendor-stubs/audio-capture-napi",
    "auto-bind": "latest",
    "axios": "latest",
    "bidi-js": "latest",
    "chalk": "latest",
    "chokidar": "latest",
    "cli-boxes": "latest",
    "code-excerpt": "latest",
    "commander": "^14.0.0",
    "color-diff-napi": "file:vendor-stubs/color-diff-napi",
    "diff": "latest",
    "emoji-regex": "latest",
    "env-paths": "latest",
    "execa": "latest",
    "figures": "latest",
