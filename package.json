{
  "name": "semiclaw-code",
  "version": "0.1.1",
  "description": "Local version of Semiclaw Code CLI inspired by Anthropic's Claude Code, but work for other AI models",
  "keywords": [
    "anthropic",
    "claude",
    "cli",
    "ai",
    "developer-tools"
  ],
  "license": "MIT",
  "author": "Anthropic",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "main": "./dist/semiclaw-code.js",
  "bin": {
    "semiclaw-code": "./dist/semiclaw-code.js"
  },
  "types": "./index.d.ts",
  "files": [
    "dist/**/*",
    "index.d.ts",
    "README.md"
  ],
  "scripts": {
    "start": "$HOME/.bun/bin/bun run -r ./src/entrypoints/preload.js ./src/entrypoints/cli.tsx",
    "help": "$HOME/.bun/bin/bun run -r ./src/entrypoints/preload.js ./src/entrypoints/cli.tsx --help",
    "build": "node build.mjs",
    "build:dev": "node build.mjs --dev",
    "build:simple": "node build.mjs",
    "prepack": "npm run build",
    "publish:npm:dry-run": "npm publish --dry-run --access public --cache /tmp/semiclaw-npm-cache",
    "publish:npm": "npm publish --access public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "bundledDependencies": [
    "@ant/claude-for-chrome-mcp",
    "@ant/computer-use-input",
    "@ant/computer-use-mcp",
    "@ant/computer-use-swift",
    "audio-capture-napi",
    "color-diff-napi",
    "modifiers-napi"
  ],
  "dependencies": {
    "@alcalzone/ansi-tokenize": "latest",
    "@ant/claude-for-chrome-mcp": "file:vendor-stubs/ant-claude-for-chrome-mcp",
    "@ant/computer-use-input": "file:vendor-stubs/ant-computer-use-input",
    "@ant/computer-use-mcp": "file:vendor-stubs/ant-computer-use-mcp",
    "@ant/computer-use-swift": "file:vendor-stubs/ant-computer-use-swift",
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@anthropic-ai/mcpb": "latest",
    "@anthropic-ai/sandbox-runtime": "latest",
    "@anthropic-ai/sdk": "latest",
    "@aws-sdk/client-bedrock-runtime": "latest",
    "@commander-js/extra-typings": "latest",
    "@growthbook/growthbook": "latest",
    "@modelcontextprotocol/sdk": "latest",
    "@opentelemetry/api": "latest",
    "@opentelemetry/api-logs": "latest",
    "@opentelemetry/core": "latest",
    "@opentelemetry/resources": "latest",
    "@opentelemetry/sdk-logs": "latest",
    "@opentelemetry/sdk-metrics": "latest",
    "@opentelemetry/sdk-trace-base": "latest",
    "@opentelemetry/semantic-conventions": "latest",
    "ajv": "latest",
